PORT=3000
NODE_ENV=production

DATABASE_URL=

JWT_ACCESS_SECRET=

REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# Pino: development defaults to debug and pretty output; production defaults to JSON info.
LOG_LEVEL=info
LOG_TO_FILE=false
# Set only when LOG_TO_FILE=true and mount this path as a persistent Coolify volume.
LOG_DIR=/app/logs
